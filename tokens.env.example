# Direct MCP AI Project — Единый файл токенов
# Скопируйте в tokens.env и заполните реальными значениями:
#   cp tokens.env.example tokens.env
#
# tokens.env добавлен в .gitignore — не попадёт в репозиторий

# ─── Yandex Search API v2 (SERP через Yandex Cloud) ───
# Получить: .claude/skills/serp-monitor/config/README.md
# Нужно: сервисный аккаунт с ролью ai.searchApi.executor + API-ключ + подключённый Search API
YANDEX_API_KEY=
YANDEX_CLOUD_FOLDER_ID=

# ─── Домен сайта (для SERP-мониторинга) ───────────────
# Ваш домен без https:// — например: etagi.com
SITE_DOMAIN=

# ─── OpenRouter (для генерации картинок РСЯ, ветка R6.5) ───
# Получить: https://openrouter.ai/keys
# Используется: server/platform/imagegen (config.go env fallback) +
# docs/campaign_previews/_gen.sh
OPENROUTER_API_KEY=

# ─── Yandex Direct OAuth (для локальных скриптов docs/campaign_previews/) ───
# Обычный рантайм MCP читает токены из server/config.yaml, эта переменная
# нужна только для прямых curl-вызовов к API v5 из хелперов в docs/.
YDIRECT_TOKEN=
