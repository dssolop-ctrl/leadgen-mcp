# Direct MCP AI Project — Единый файл токенов
# Скопируйте в tokens.env и заполните реальными значениями:
#   cp tokens.env.example tokens.env
#
# tokens.env добавлен в .gitignore — не попадёт в репозиторий

# ─── Yandex Cloud (для Yandex Search API / SERP) ──────
# Получить: см. .claude/skills/serp-monitor/config/README.md
YANDEX_CLOUD_OAUTH_TOKEN=
YANDEX_CLOUD_FOLDER_ID=

# ─── Yandex XML (альтернатива Cloud для поиска) ───────
# Получить: https://xml.yandex.ru/
YANDEX_XML_USER=
YANDEX_XML_KEY=

# ─── Домен сайта (для SERP-мониторинга) ───────────────
# Ваш домен без https:// — например: example.com
SITE_DOMAIN=
