    {
      "type": "text",
      "id": "cc_modes_title",
      "x": 1680,
      "y": 1285,
      "width": 780,
      "height": 26,
      "text": "1.  Режимы работы — объявляется в первом сообщении",
      "originalText": "1.  Режимы работы — объявляется в первом сообщении",
      "fontSize": 16,
      "fontFamily": 3,
      "textAlign": "left",
      "verticalAlign": "top",
      "strokeColor": "#c2410c",
      "backgroundColor": "transparent",
      "fillStyle": "solid",
      "strokeWidth": 1,
      "strokeStyle": "solid",
      "roughness": 0,
      "opacity": 100,
      "angle": 0,
      "seed": 600012,
      "version": 1,
      "versionNonce": 600013,
