    {
      "type": "text",
      "id": "cc_serp_title",
      "x": 1680,
      "y": 1985,
      "width": 1720,
      "height": 28,
      "text": "5.  SERP-monitor — «взгляд на рынок»  (дополняет Direct)",
      "originalText": "5.  SERP-monitor — «взгляд на рынок»  (дополняет Direct)",
      "fontSize": 16,
      "fontFamily": 3,
      "textAlign": "left",
      "verticalAlign": "top",
      "strokeColor": "#0e7490",
      "backgroundColor": "transparent",
      "fillStyle": "solid",
      "strokeWidth": 1,
      "strokeStyle": "solid",
      "roughness": 0,
      "opacity": 100,
      "angle": 0,
      "seed": 800003,
      "version": 1,
      "versionNonce": 800004,
      "isDeleted": false,
      "groupIds": [],
      "boundElements": null,
      "link": null,
