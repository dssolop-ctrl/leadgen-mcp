      "opacity": 100,
      "angle": 0,
      "strokeColor": "#334155",
      "backgroundColor": "transparent",
      "seed": 9000004,
      "versionNonce": 9000005,
      "groupIds": [],
      "frameId": null,
      "roundness": null,
      "boundElements": [],
      "updated": 1,
      "link": null,
      "locked": false,
      "isDeleted": false,
      "fontSize": 14,
      "fontFamily": 2,
      "text": "Отдельный флоу для рекламной сети. Роутер 2 на C1/R1 выбирает канал. Широкая семантика, кластеризация по аудитории, генерация картинок через OpenRouter (лимит 20/кампанию), переиспользование AdImageHash между группами.",
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "Отдельный флоу для рекламной сети. Роутер 2 на C1/R1 выбирает канал. Широкая семантика, кластеризация по аудитории, генерация картинок через OpenRouter (лимит 20/кампанию), переиспользование AdImageHash между группами.",
      "lineHeight": 1.25,
      "baseline": 12
