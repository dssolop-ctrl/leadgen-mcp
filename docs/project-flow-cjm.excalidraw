      "width": 790,
      "height": 28,
      "text": "[camp] campaigns/<slug>.md — per-campaign state",
      "originalText": "[camp] campaigns/<slug>.md — per-campaign state",
      "fontSize": 15,
      "fontFamily": 3,
      "textAlign": "left",
      "verticalAlign": "top",
      "strokeColor": "#047857",
