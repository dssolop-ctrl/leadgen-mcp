    {
      "type": "text",
      "id": "cc_infra_title",
      "x": 2520,
      "y": 1625,
      "width": 780,
      "height": 26,
      "text": "4.  Инфраструктура + UI naming + LEGAL + история",
      "originalText": "4.  Инфраструктура + UI naming + LEGAL + история",
      "fontSize": 16,
      "fontFamily": 3,
      "textAlign": "left",
      "verticalAlign": "top",
      "strokeColor": "#6d28d9",
      "backgroundColor": "transparent",
      "fillStyle": "solid",
      "strokeWidth": 1,
      "strokeStyle": "solid",
      "roughness": 0,
      "opacity": 100,
      "angle": 0,
      "seed": 600042,
      "version": 1,
      "versionNonce": 600043,
      "isDeleted": false,
      "groupIds": [],
