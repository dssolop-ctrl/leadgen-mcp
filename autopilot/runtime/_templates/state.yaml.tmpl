# state.yaml — операционный источник правды (machine).
# Schema: ../../schemas/state.schema.json
# Регенерируется в конце каждого прогона.
city: "{{ city }}"
schema_version: 1
last_run:
  run_id: "{{ run_id }}"
  started_at: "{{ started_at }}"
  ended_at: "{{ ended_at }}"
  status: "{{ status }}"           # succeeded | failed | halted | in_progress
  phase: "{{ phase }}"
  autopilot_version: "{{ autopilot_version }}"
  skill_version: "{{ skill_version }}"
  autonomy_mode: "{{ autonomy_mode }}"
budget:
  monthly_total_limit: {{ monthly_total_limit }}
  spent_mtd: {{ spent_mtd }}
  managed_spend_mtd: {{ managed_spend_mtd }}
  unmanaged_spend_mtd: {{ unmanaged_spend_mtd }}
  pacing_ratio: {{ pacing_ratio }}
  forecast_month_end: {{ forecast_month_end }}
  pacing_state: "{{ pacing_state }}"   # normal | conservation | emergency | hard_cap
topics:
