# Copy to secrets.env and fill in real values. secrets.env is gitignored.
#
# Required for Telegram notify:
TELEGRAM_BOT_TOKEN=123456789:ABCdefGhIJKlmnoPQRstuVWXyz
TELEGRAM_ALLOWLIST_CHAT_IDS=-1001234567890,-1009876543210

# Optional: HTTP timeout (sec) for curl-based Telegram calls
TELEGRAM_HTTP_TIMEOUT=15

# Optional: OpenRouter API key for creative.generate_new_image
# (handled by MCP server side; here only if scripts need direct access)
OPENROUTER_API_KEY=

# Optional: override autopilot version label shown in reports
AUTOPILOT_VERSION_LABEL=
